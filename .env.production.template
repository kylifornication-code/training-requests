# Production Environment Variables Template
# Copy this file to .env.production and fill in the actual values
# DO NOT commit the actual .env.production file to version control

# Django Core Settings
DEBUG=False
SECRET_KEY=your-super-secret-key-here-change-this-in-production
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,your-server-ip

# Database Configuration
# Choose either 'postgresql' or 'mysql'
DATABASE_ENGINE=postgresql
DATABASE_NAME=training_system_prod
DATABASE_USER=training_user
DATABASE_PASSWORD=your-database-password
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_SSLMODE=require
DATABASE_CONN_MAX_AGE=60

# For MySQL, use these instead:
# DATABASE_ENGINE=mysql
# DATABASE_PORT=3306

# Static and Media Files
STATIC_ROOT=/var/www/training_system/static
MEDIA_ROOT=/var/www/training_system/media

# Security Settings
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_CONTENT_TYPE_NOSNIFF=True
SECURE_BROWSER_XSS_FILTER=True
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin

# Session and CSRF Security
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Strict
CSRF_COOKIE_SECURE=True
CSRF_COOKIE_HTTPONLY=True
CSRF_COOKIE_SAMESITE=Strict
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=Training System <noreply@yourdomain.com>
SERVER_EMAIL=Training System <server@yourdomain.com>

# Microsoft Teams Integration
TEAMS_WEBHOOK_URL=https://your-organization.webhook.office.com/webhookb2/your-webhook-url
BASE_URL=https://yourdomain.com

# Caching Configuration
CACHE_BACKEND=django.core.cache.backends.locmem.LocMemCache
CACHE_LOCATION=
CACHE_TIMEOUT=300
CACHE_MAX_ENTRIES=1000

# For Redis caching, use these instead:
# CACHE_BACKEND=django_redis.cache.RedisCache
# CACHE_LOCATION=redis://127.0.0.1:6379/1
# REDIS_MAX_CONNECTIONS=20

# Logging Configuration
LOG_FILE=/var/log/training_system/django.log
NOTIFICATIONS_LOG_FILE=/var/log/training_system/notifications.log
SECURITY_LOG_FILE=/var/log/training_system/security.log
LOG_MAX_BYTES=15728640
LOG_BACKUP_COUNT=5

# Admin Configuration
# Format: Name:email,Name2:email2
ADMINS=Admin Name:admin@yourdomain.com,Tech Lead:tech@yourdomain.com

# Performance Settings
DATA_UPLOAD_MAX_MEMORY_SIZE=5242880
FILE_UPLOAD_MAX_MEMORY_SIZE=5242880
SESSION_COOKIE_AGE=3600

# Localization
TIME_ZONE=UTC
USE_I18N=True
USE_TZ=True
LANGUAGE_CODE=en-us

# Proxy Settings (if behind reverse proxy)
USE_X_FORWARDED_HOST=True
USE_X_FORWARDED_PORT=True

# Optional: Sentry Error Tracking
# SENTRY_DSN=https://your-sentry-dsn-here

# Optional: AWS S3 for static/media files
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_STORAGE_BUCKET_NAME=your-s3-bucket-name
# AWS_S3_REGION_NAME=us-east-1